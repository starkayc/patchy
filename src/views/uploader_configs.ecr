        <span class="config-card-badge">Image uploader</span>
      </div>
      <p class="config-card-desc"><%= translate(locale, "uploader_configs_chatterino_text") %></p>
      <div class="config-fields">
        <div class="config-field">
          <span class="config-field-label">Request URL</span>
          <div class="config-field-value">
            <code><%= scheme %>://<%= host %>/-/upload</code>
            <button class="button copy-button" onclick="copyValue(this, '<%= scheme %>://<%= host %>/-/upload')">Copy</button>
          </div>
        </div>
